# Required for live inference
RTSP_URL=rtsp://wyze-bridge.railway.internal:8554/birdhouse
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tunables
MOTION_THRESHOLD=25
DETECTION_CONFIDENCE_THRESHOLD=0.45
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.25
DEBOUNCE_SECONDS=45
FRAME_SKIP=2
RECONNECT_DELAY_SECONDS=2

# Models
BIRD_MODEL_PATH=yolov8n.pt
SPECIES_MODEL_ID=chriamue/bird-species-classifier
ENABLE_SPECIES_CLASSIFIER=true

# Ops
DRY_RUN=false
HOST=0.0.0.0
PORT=8080
