# Required for live inference
RTSP_URL=rtsp://wyze-bridge.railway.internal:8554/bird
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tunables
MOTION_THRESHOLD=25
DETECTION_CONFIDENCE_THRESHOLD=0.45
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.75
CLASSIFICATION_MARGIN_THRESHOLD=0.15
UNKNOWN_MIN_CONFIDENCE=0.20
MIN_CAPTURE_SECONDS=3
CAPTURE_SAMPLE_INTERVAL_SECONDS=0.5
DEBOUNCE_SECONDS=60
FRAME_SKIP=2
RECONNECT_DELAY_SECONDS=2
RECENT_IMAGE_LIMIT=6

# Models
BIRD_MODEL_PATH=yolov8n.pt
SPECIES_MODEL_ID=houlette/birdclass-na
ENABLE_SPECIES_CLASSIFIER=true

# Ops
DRY_RUN=false
HOST=0.0.0.0
PORT=8080
