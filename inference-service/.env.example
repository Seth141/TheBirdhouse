# Required for live inference
RTSP_URL=rtsp://wyze-bridge.railway.internal:8554/bird
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tunables
# Motion is ROI + concentration filtered to ignore windy leaves
MOTION_THRESHOLD=30
# x,y,width,height as fractions of the frame (0–1). Default = birdhouse area.
MOTION_ROI=0.10,0.20,0.80,0.75
MOTION_MIN_AREA_FRACTION=0.004
MOTION_MAX_AREA_FRACTION=0.20
MOTION_MIN_CONCENTRATION=0.40
DETECTION_CONFIDENCE_THRESHOLD=0.25
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.75
CLASSIFICATION_MARGIN_THRESHOLD=0.15
UNKNOWN_MIN_CONFIDENCE=0.20
# Short dense burst for fast birds (titmice)
MIN_CAPTURE_SECONDS=1.5
CAPTURE_SAMPLE_INTERVAL_SECONDS=0.15
DEBOUNCE_SECONDS=60
FRAME_SKIP=2
RECONNECT_DELAY_SECONDS=2
RECENT_IMAGE_LIMIT=6

# Models
BIRD_MODEL_PATH=yolov8n.pt
SPECIES_MODEL_ID=houlette/birdclass-na
ENABLE_SPECIES_CLASSIFIER=true

# Ops
DRY_RUN=false
HOST=0.0.0.0
PORT=8080
