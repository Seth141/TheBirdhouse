# Supabase (frontend — anon key only, never the service role)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Live camera — prefer same-origin proxy (recommended)
NEXT_PUBLIC_CAMERA_PROTOCOL=hls
NEXT_PUBLIC_CAMERA_STREAM_URL=/api/camera/bird/stream.m3u8

# Server-only upstream for /api/camera/[...path] (never NEXT_PUBLIC_*)
CAMERA_UPSTREAM_BASE=https://YOUR_WYZE_BRIDGE_HOST
CAMERA_STREAM_USER=wb
CAMERA_STREAM_PASSWORD=your-wb-api-key-from-bridge-webui

# Optional: still frame for home card poster
# NEXT_PUBLIC_CAMERA_SNAPSHOT_URL=

# Tip of the Day (server-only)
OPENAI_API_KEY=

# Optional site password gate
# SITE_PASSWORD=
