# Supabase (frontend — anon key only, never the service role)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Live camera — prefer same-origin proxy (recommended)
NEXT_PUBLIC_CAMERA_PROTOCOL=hls
NEXT_PUBLIC_CAMERA_STREAM_URL=/api/camera/bird/stream.m3u8

# Server-only upstream for /api/camera/[...path] (never NEXT_PUBLIC_*)
CAMERA_UPSTREAM_BASE=https://YOUR_WYZE_BRIDGE_HOST
CAMERA_STREAM_USER=wb
CAMERA_STREAM_PASSWORD=your-wb-api-key-from-bridge-webui

# On-demand Railway wyze-bridge (start on Live Cam tap, stop after idle)
# Token: https://railway.com/account/tokens → Create → "No workspace" (Account token)
# Must be the secret token string — NOT a project/service UUID from Cmd+K
RAILWAY_API_TOKEN=
# IDs: open wyze-bridge project → Cmd+K → "Copy Service ID" / "Copy Environment ID"
RAILWAY_SERVICE_ID=
RAILWAY_ENVIRONMENT_ID=
CAMERA_IDLE_MINUTES=12
# Combined Railway service runs camera + inference daytime only
# Sleep window is fixed: 8:00 PM – 5:00 AM America/Los_Angeles (Pacific)
CAMERA_MONITORING_ENABLED=true
# Optional: protect /api/bridge/idle-check (Authorization: Bearer …)
# CRON_SECRET=

# Overnight schedule (GitHub Actions): set these IDs/token as repo secrets so
# .github/workflows/railway-start.yml / railway-stop.yml can run scripts/railway-toggle.js
# Optional Project ID is dashboard-only — not required by the toggle script.

# Optional: still frame for home card poster
# NEXT_PUBLIC_CAMERA_SNAPSHOT_URL=

# Tip of the Day (server-only)
OPENAI_API_KEY=

# Optional site password gate
# SITE_PASSWORD=
